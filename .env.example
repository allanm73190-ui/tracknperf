# Track'n'Perf — Environment Variables
# Copy to .env.local and fill in your values.
# Never commit .env.local or any file containing real keys.

# Supabase project URL (found in Supabase Dashboard > Settings > API)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon/public key — safe to expose in browser bundles,
# but keep it out of source control. RLS enforces data isolation.
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# App version — injected at build time (e.g. from package.json or CI tag)
VITE_APP_VERSION=0.1.0

